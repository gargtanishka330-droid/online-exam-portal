              "name": "Delete Exam",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{adminToken}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "DELETE",
                "header": [],
                "url": "{{baseUrl}}/api/admin/exam/{{examId}}"
              }
            }
          ]
        },
